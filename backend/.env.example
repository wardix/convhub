# Environment
# Set to 'production' for production builds, 'development' otherwise
NODE_ENV=development

# Server Port
PORT=3000

# Database Connection String
# e.g., postgres://user:pass@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/convhub

# JWT Secrets (Required in production)
# Generate secure random strings for these in production
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# OAuth Providers (Required for OAuth login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (Used for CORS and redirect URLs)
FRONTEND_URL=http://localhost:5173
